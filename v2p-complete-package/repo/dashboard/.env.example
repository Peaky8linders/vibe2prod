# VibeCheck Dashboard Environment Variables

# GitHub App Integration (for PR-level scanning)
# Create a GitHub App at: https://github.com/settings/apps/new
# Use github-app-manifest.json for configuration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Public-facing GitHub App URL (for setup page install button)
NEXT_PUBLIC_GITHUB_APP_URL=https://github.com/apps/vibecheck-security/installations/new
