# =============================================================================
# .env.example — Copy to .env and fill in values
# NEVER commit .env to source control
# =============================================================================

# App
APP_PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Database
DB_USER=app
DB_PASSWORD=          # REQUIRED: generate with `openssl rand -base64 32`
DB_NAME=taskdb
DB_PORT=5432

# Auth
JWT_SECRET=           # REQUIRED: generate with `openssl rand -base64 64`

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# External APIs (if used)
SYNC_API_KEY=
SENDGRID_API_KEY=

# Anthropic (for L2 judges)
ANTHROPIC_API_KEY=
